# ─── Versions ────────────────────────────────────────────────────────────────
NODE_VERSION=20
POSTGRES_VERSION=16

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=bazaar
POSTGRES_USER=bazaar_user
